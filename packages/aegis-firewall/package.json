{
  "name": "aegis-firewall",
  "version": "0.1.0",
  "description": "A lightweight TypeScript firewall SDK for scanning, scoring, and sanitizing LLM inputs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "keywords": [
    "llm",
    "firewall",
    "security",
    "prompt-injection",
    "ai-safety"
  ],
  "license": "MIT"
}
